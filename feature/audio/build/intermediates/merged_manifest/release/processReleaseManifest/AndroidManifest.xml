<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.avozdedeus.avozdedeusjpc.audio" >

    <uses-sdk android:minSdkVersion="30" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application>
        <activity
            android:name="com.avozdedeus.avozdedeusjpc.audio.AudioActivity"
            android:exported="false"
            android:theme="@style/Theme.AVozDeDeusJPC" />

        <service
            android:name="com.avozdedeus.avozdedeusjpc.audio.AudioPlaybackService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback" >
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>
    </application>

</manifest>